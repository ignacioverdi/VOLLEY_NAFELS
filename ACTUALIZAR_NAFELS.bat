REM === 2) Decodificar base64 -> update_db_nafels_FULL.py ===
powershell -NoProfile -Command "[IO.File]::WriteAllText('update_db_nafels_FULL.py', [Text.Encoding]::UTF8.GetString([Convert]::FromBase64String((Get-Content -Raw '_gen_nafels.b64').Replace('`r','').Replace('`n',''))))"
del "_gen_nafels.b64"

REM === 3) Detectar carpeta de DVW (ajusta esta ruta si hace falta) ===
set "DVW_DIR="
REM Carpeta de PARTIDOS = "DVW NAFELS <ano>", NUNCA la de entrenamientos.
REM Recorre todas las "DVW NAFELS *", descarta ENTRENAMIENTOS, y elige la del ano MAS NUEVO.
for /f "delims=" %%D in ('dir /b /ad /o-n "DVW NAFELS *" 2^>nul') do (
  echo %%D | findstr /I "ENTREN" >nul || if not defined DVW_DIR set "DVW_DIR=%%D"
)
REM Respaldos por si el nombre es distinto
if not defined DVW_DIR if exist "DVW NAFELS 2027" set "DVW_DIR=DVW NAFELS 2027"
if not defined DVW_DIR if exist "DVW NAFELS 2026" set "DVW_DIR=DVW NAFELS 2026"
if not defined DVW_DIR if exist "DVW_NAFELS" set "DVW_DIR=DVW_NAFELS"
if not defined DVW_DIR set "DVW_DIR=."
echo Carpeta de DVW detectada: "%DVW_DIR%"
REM Contar DVW en esa carpeta para avisar si esta vacia
set "NDVW=0"
for %%F in ("%DVW_DIR%\*.dvw") do set /a NDVW+=1
echo Archivos DVW encontrados: %NDVW%
if "%NDVW%"=="0" (
  echo.
  echo  ATENCION: la carpeta no tiene archivos .dvw  ^(o es la equivocada^).
  echo  Verifica que "%DVW_DIR%" sea la carpeta de PARTIDOS.
  echo.
  pause
)

echo [1/3] Procesando partidos y regenerando el sistema COMPLETO...
python update_db_nafels_FULL.py --dvw_dir "%DVW_DIR%" --temporada 2026 --output_dir .
if errorlevel 1 (
  echo ERROR al correr el generador. Revisa que Python este instalado.
  pause
  exit /b 1
)

echo [2/3] Generando videos y proximo rival desde el Excel...
if exist "gen_videos.py" python gen_videos.py

echo [3/3] Verificando que datos_partidos.js quedo COMPLETO...
findstr /C:"PARTIDOS_ARMADOR" datos_partidos.js >nul && (echo   OK: armador presente) || (echo   FALTA armador - avisa)
findstr /C:"PARTIDOS_TRANSICION" datos_partidos.js >nul && (echo   OK: transicion presente) || (echo   FALTA transicion - avisa)
findstr /C:"PARTIDOS_INDIVIDUAL" datos_partidos.js >nul && (echo   OK: partidos individuales presentes) || (echo   FALTA individuales - avisa)

echo ==================================================
echo     SUBIR A GITHUB (VOLLEY_NAFELS):
echo ==================================================
echo     - datos_partidos.js   (armador + transicion + todo)
echo     - liga_data.js
echo     - nla_stats_table.html  (o casla_stats_table.html)
echo     - videos.js  proximo_rival.js  (si cambiaron)
echo     Los HTML (armadores, jugador, etc) solo si los cambie yo.
echo ==================================================
pause
